{
  "name": "@agentpayxyz/mcp-server",
  "version": "0.2.0",
  "mcpName": "io.github.Rumblingb/agentpay",
  "description": "MCP server for AgentPay — autonomous agent infrastructure for payments, API key vaulting, and governed mandates. One OTP vaults credentials so agents never handle raw API keys. Agents spend money within user-defined limits. Works with Claude, GPT-4o, and any MCP host.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "agentpay-mcp": "./bin/agentpay-mcp.mjs"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "bin", "README.md", "server.json"],
  "scripts": {
    "build": "tsc",
    "dev": "node --watch dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "agentpay",
    "mcp",
    "model-context-protocol",
    "ai-agents",
    "payments",
    "claude",
    "anthropic",
    "agentpassport",
    "api-key-management",
    "api-key-vault",
    "credential-management",
    "capability-vault",
    "mandate",
    "agent-billing",
    "agent-payments",
    "spending-limits",
    "zero-api-key",
    "autonomous-agents",
    "agent-infrastructure",
    "mcp-payments",
    "stripe-agent",
    "upi",
    "firecrawl",
    "perplexity",
    "openai-proxy",
    "agent-identity",
    "agentpassport",
    "rotate-api-key",
    "secure-credentials",
    "governed-agent"
  ],
  "author": "AgentPay",
  "license": "BSL-1.1; AGPL-3.0 after 2029-01-01",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Rumblingb/Agentpay.git",
    "directory": "packages/mcp-server"
  },
  "homepage": "https://github.com/Rumblingb/Agentpay/tree/main/packages/mcp-server#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
