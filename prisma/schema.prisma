generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"] // <--- ADD THIS LINE
  // output = "../src/generated/prisma" (keep if you prefer Option B)
}
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
model Merchant {
  id                       String    @id @default(uuid()) @db.Uuid
  name                     String
  email                    String    @unique
  apiKeyHash               String    @map("api_key_hash")
  apiKeySalt               String    @map("api_key_salt")
  keyPrefix                String    @map("key_prefix")
  walletAddress            String    @map("wallet_address")
  webhookUrl               String?   @map("webhook_url")
  stripeConnectedAccountId String?   @map("stripe_connected_account_id")
  isActive                 Boolean?  @default(true) @map("is_active")
  createdAt                DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                DateTime? @updatedAt @map("updated_at") @db.Timestamptz(6)

  paymentIntents PaymentIntent[]
  agents         Agent[]

  @@map("merchants")
}

// First-class agent entity — owns intents and carries identity/risk data.
// Network fields (service, endpointUrl, etc.) support the AgentPay Network marketplace.
model Agent {
  id             String    @id @default(uuid()) @db.Uuid
  merchantId     String?   @map("merchant_id") @db.Uuid
  merchant       Merchant? @relation(fields: [merchantId], references: [id])
  displayName    String    @map("display_name")
  publicKey      String?   @map("public_key")
  riskScore      Int       @default(500) @map("risk_score")
  // AgentPay Network marketplace fields
  service        String?
  endpointUrl    String?   @map("endpoint_url")
  pricingModel   Json?     @default("{}") @map("pricing_model")
  rating         Float     @default(5.0)
  totalEarnings  Float     @default(0) @map("total_earnings")
  tasksCompleted Int       @default(0) @map("tasks_completed")
  // Semantic discovery — pgvector column (optional, requires pgvector extension)
  embedding      Unsupported("vector(1536)")?
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  intents        PaymentIntent[]

  @@map("agents")
}

// AgentPay Network: records every agent-to-agent job/hire.
model AgentTransaction {
  id            String   @id @default(cuid())
  buyerAgentId  String   @map("buyer_agent_id")
  sellerAgentId String   @map("seller_agent_id")
  task          Json
  status        String   @default("pending")
  amount        Float
  escrowId      String?  @map("escrow_id")
  output        Json?
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("agent_transactions")
}

// AgentPay Network: escrow record per hire.
model AgentEscrow {
  id            String   @id @default(cuid())
  transactionId String   @map("transaction_id")
  amount        Float
  status        String   @default("locked")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("agent_escrow")
}

// AgentPay Network: per-agent reputation derived from network transactions.
// TODO: extend into a full trust graph (success chains, peer endorsements).
model AgentReputation {
  id              String   @id @default(cuid())
  agentId         String   @unique @map("agent_id")
  successRate     Float    @default(1.0) @map("success_rate")
  disputeRate     Float    @default(0.0) @map("dispute_rate")
  avgResponseTime Int      @default(0) @map("avg_response_time")
  rating          Float    @default(5.0)
  totalTx         Int      @default(0) @map("total_tx")
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("agent_reputation_network")
}

model PaymentIntent {
  id                String    @id @db.Uuid
  merchantId        String    @map("merchant_id") @db.Uuid
  agentId           String?   @map("agent_id") @db.Uuid
  amount            Decimal   @db.Decimal(20, 6)
  currency          String    @default("USDC")
  status            String    @default("pending")
  protocol          String?
  verificationToken String    @unique @map("verification_token")
  expiresAt         DateTime  @map("expires_at")
  metadata          Json?
  createdAt         DateTime? @default(now()) @map("created_at")
  updatedAt         DateTime? @updatedAt @map("updated_at")

  merchant Merchant @relation(fields: [merchantId], references: [id])
  agent    Agent?   @relation(fields: [agentId], references: [id])

  @@map("payment_intents")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model payment_audit_log {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  merchant_id           String?   @db.Uuid
  ip_address            String?
  transaction_signature String?
  endpoint              String?
  method                String?
  succeeded             Boolean?
  failure_reason        String?
  created_at            DateTime? @default(now()) @db.Timestamptz(6)
}

model transactions {
  id                       String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  merchant_id              String    @db.Uuid
  payment_id               String    @unique @db.Uuid
  amount_usdc              Decimal   @db.Decimal(20, 6)
  recipient_address        String
  payer_address            String?
  transaction_hash         String?
  stripe_payment_reference String?
  status                   String?   @default("pending")
  webhook_status           String?   @default("not_sent")
  confirmation_depth       Int?      @default(0)
  required_depth           Int?      @default(2)
  expires_at               DateTime?
  metadata                 Json?
  created_at               DateTime? @default(now()) @db.Timestamptz(6)
  updated_at               DateTime? @db.Timestamptz(6)
}

