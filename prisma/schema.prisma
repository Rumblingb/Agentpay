// PRODUCTION FIX — INSURANCE POOL TABLE
// Backstop for the Behavioral Oracle — holds USDC reserves for automated
// insurance payouts when critical alerts trigger reputation slashing.
// Migration: npx prisma db push  (or add migration via npx prisma migrate dev)
model insurance_pool {
  id                   Int      @id @default(autoincrement())
  current_balance_usdc Decimal  @db.Decimal(20, 6)
  max_coverage_per_tx  Decimal  @default(100.00) @db.Decimal(20, 6)
  total_claims         Int      @default(0)
  updated_at           DateTime @updatedAt

  @@map("insurance_pool")
}

// PRODUCTION FIX — ADDED BY COPILOT: Dispute resolution cases table
model dispute_cases {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  escrow_id        String
  hiring_agent     String
  working_agent    String
  amount_usdc      Decimal   @db.Decimal(20, 6)
  evidence         Json?     @default("{}")
  completion_score Decimal?  @db.Decimal(5, 3)
  peer_reviews     Json?     @default("[]")
  outcome          String?
  worker_payout    Decimal   @default(0) @db.Decimal(20, 6)
  hirer_refund     Decimal   @default(0) @db.Decimal(20, 6)
  resolved         Boolean   @default(false)
  resolved_at      DateTime? @db.Timestamptz(6)
  created_at       DateTime? @default(now()) @db.Timestamptz(6)
}

// Hosted/custodial wallet for walletless agents (e.g. Moltbook bots).
// The private key is stored AES-256-GCM encrypted via walletEncryption.ts.
model agent_wallets {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agent_id              String    @unique
  public_key            String
  encrypted_private_key String
  balance_usdc          Decimal   @default(0) @db.Decimal(20, 6)
  label                 String?
  is_active             Boolean   @default(true)
  created_at            DateTime? @default(now()) @db.Timestamptz(6)
  updated_at            DateTime? @default(now()) @db.Timestamptz(6)

  @@map("agent_wallets")
}

// ─── Foundation Agents — Database Models ─────────────────────────────────────

// Agent-to-agent fee ledger: every service charge from the 4 constitutional
// agents lands here so it can be audited without touching the merchant
// transactions table.
model AgentFeeTransaction {
  id          String   @id @default(cuid())
  fromAgent   String   @map("from_agent")
  toAgent     String   @map("to_agent")
  amount      Float
  status      String   @default("completed")
  description String?
  metadata    Json?    @default("{}")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("agent_fee_transactions")
}

// IdentityVerifierAgent — issued identity credentials
model VerificationCredential {
  id         String   @id
  agentId    String   @map("agent_id")
  agent      Agent    @relation(fields: [agentId], references: [id])
  operatorId String   @map("operator_id")
  environment Json
  issuedAt   DateTime @map("issued_at")
  expiresAt  DateTime @map("expires_at")
  signature  String
  trustLevel String   @map("trust_level")
  revoked    Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("verification_credentials")
}

// IdentityVerifierAgent — cross-platform identity links
model IdentityLink {
  id                 String   @id
  primaryAgentId     String   @map("primary_agent_id")
  primaryAgent       Agent    @relation(fields: [primaryAgentId], references: [id])
  linkedAgentIds     String[] @map("linked_agent_ids")
  crossPlatformProof Json     @map("cross_platform_proof")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("identity_links")
}

// ReputationOracleAgent — query audit log
model ReputationQueryLog {
  id                String   @id @default(cuid())
  requestingAgentId String   @map("requesting_agent_id")
  queriedAgentId    String   @map("queried_agent_id")
  depth             String   @default("standard")
  trustScore        Float    @map("trust_score")
  riskLevel         String   @map("risk_level")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("reputation_query_logs")
}

// DisputeResolverAgent — structured dispute cases
model Dispute {
  id            String    @id
  transactionId String    @map("transaction_id")
  claimant      String
  respondent    String
  claim         String
  category      String
  evidence      Json      @default("{\"claimant\":[],\"respondent\":[]}")
  status        String    @default("filed")
  resolution    Json?
  filedAt       DateTime  @default(now()) @map("filed_at") @db.Timestamptz(6)
  resolvedAt    DateTime? @map("resolved_at") @db.Timestamptz(6)

  @@map("disputes")
}

// Trust event spine — canonical store for all trust-affecting events.
// Queried by GET /api/v1/trust/events.
model TrustEvent {
  id             String   @id @default(cuid())
  eventType      String   @map("event_type")
  agentId        String   @map("agent_id")
  counterpartyId String?  @map("counterparty_id")
  delta          Int      @default(0)
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([agentId])
  @@index([eventType])
  @@index([createdAt(sort: Desc)])
  @@map("trust_events")
}

// IntentCoordinatorAgent — multi-protocol routing log
model CoordinatedTransaction {
  id           String    @id @default(cuid())
  intentId     String    @unique @map("intent_id")
  fromAgent    String    @map("from_agent")
  toAgent      String    @map("to_agent")
  amount       Float
  currency     String
  purpose      String
  status       String    @default("pending")
  route        Json
  steps        Json      @default("[]")
  externalTxId String?   @map("external_tx_id")
  metadata     Json?     @default("{}")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  completedAt  DateTime? @map("completed_at") @db.Timestamptz(6)

  @@map("coordinated_transactions")
}
