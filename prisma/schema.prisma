  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agent_id           String
  alert_type         String
  severity           String    @default("low")
  description        String?
  auto_paused        Boolean   @default(false)
  reputation_penalty Int       @default(0)
  metadata           Json?     @default("{}")
  created_at         DateTime? @default(now()) @db.Timestamptz(6)
}

// PRODUCTION FIX — ADDED BY COPILOT: KYA (Know Your Agent) identity table
model agent_identities {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agent_id        String    @unique
  owner_email     String
  owner_id        String?
  verified        Boolean   @default(false)
  kyc_status      String    @default("pending")
  risk_score      Decimal   @default(0) @db.Decimal(5, 2)
  stripe_account  String?
  platform_token  String?
  world_id_hash   String?
  metadata        Json?     @default("{}")
  created_at      DateTime? @default(now()) @db.Timestamptz(6)
