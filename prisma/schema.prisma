model PaymentIntent {
  id                String    @id @db.Uuid
  merchantId        String    @map("merchant_id") @db.Uuid
  agentId           String?   @map("agent_id") @db.Uuid
  amount            Decimal   @db.Decimal(20, 6)
  currency          String    @default("USDC")
  status            String    @default("pending")
  protocol          String?
  verificationToken String    @unique @map("verification_token")
  expiresAt         DateTime  @map("expires_at")
  // First-class protocol-specific external reference.
  // Replaces the metadata->>'tx_hash' side-channel used by the Solana listener.
  // Populated when an agent submits a transaction hash via POST /:intentId/verify.
  externalRef       String?   @map("external_ref")
  // Business-level fee model override.
  // Overrides global platform fee defaults when set (e.g. zero-fee for trial merchants).
  // Kept at intent level, not inside MatchingPolicy, so fee logic stays per-intent.
  feeConfiguration  Json?     @map("fee_configuration")
  metadata          Json?
  createdAt         DateTime? @default(now()) @map("created_at")
  updatedAt         DateTime? @updatedAt @map("updated_at")

  merchant             Merchant              @relation(fields: [merchantId], references: [id])
  agent                Agent?                @relation(fields: [agentId], references: [id])
  settlementIdentities SettlementIdentity[]
  resolution           IntentResolution?

  @@map("payment_intents")
}

