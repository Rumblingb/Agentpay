// ─── Phase 2: Settlement Identity Layer ──────────────────────────────────────
//
// These four models implement protocol-native settlement matching without
// touching existing payment or intent tables. All changes are additive.
//
// Relationship summary:
//   PaymentIntent ──< SettlementIdentity ──< SettlementEvent
//   PaymentIntent ──  IntentResolution   ──> SettlementIdentity
//   MatchingPolicy is a standalone config table (no FK to other models)

// One record per (intent, protocol) pair. Links a payment intent to the
// external proof of settlement for a specific protocol rail.
// Replaces the scattered metadata->>'tx_hash' / stripe_payment_reference
// side-channels with a first-class, indexed, protocol-aware record.
model SettlementIdentity {
  id          String    @id @default(uuid()) @db.Uuid
  intentId    String    @map("intent_id") @db.Uuid
  protocol    String
  // Protocol-specific external reference: Solana txHash, Stripe sessionId,
  // AP2 verificationToken, etc. Nullable until the payer submits proof.
  externalRef String?   @map("external_ref")
  status      String    @default("pending")
  settledAt   DateTime? @map("settled_at") @db.Timestamptz(6)
  metadata    Json?     @default("{}")
  // true when this is the canonical identity for the intent (e.g. after a retry,
  // only the successful identity is marked primary).
  isPrimary   Boolean   @default(false) @map("is_primary")
  // Ordering hint — higher value = preferred identity when multiple exist.
  priority    Int       @default(0)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  intent     PaymentIntent     @relation(fields: [intentId], references: [id])
  events     SettlementEvent[]
  resolution IntentResolution?

  @@index([intentId])
  @@index([externalRef])
  @@index([protocol])
  @@index([status])
  @@map("settlement_identities")
}

// Per-protocol configuration for how settlement evidence is matched to intents.
// Seeded at migration time with defaults for every supported protocol.
// Operators can update rows to tune matching behaviour without code deploys.
model MatchingPolicy {
  id                String   @id @default(uuid()) @db.Uuid
  // One active policy per protocol (enforced at application layer, not DB unique,
  // to allow A/B policy testing via is_active flag).
  protocol          String
  // How to identify the payer's proof: by_recipient | by_memo | by_external_ref
  matchStrategy     String   @map("match_strategy")
  // If true, the Solana Pay memo must equal payment_intents.verification_token.
  requireMemoMatch  Boolean  @default(false) @map("require_memo_match")
  // Minimum on-chain confirmations required before marking a Solana payment confirmed.
  confirmationDepth Int      @default(2) @map("confirmation_depth")
  // Seconds from intent creation until it auto-expires.
  ttlSeconds        Int      @default(1800) @map("ttl_seconds")
  isActive          Boolean  @default(true) @map("is_active")
  // First-class fee source: 'payer' | 'merchant' | 'split' | 'waived'.
  // Promoted from config JSONB for clarity; overrides config->>'feeSourcePolicy'.
  allowedFeeSource  String?  @map("allowed_fee_source")
  // Amount tolerance in basis points (e.g. 50 = 0.50%).
  // Replaces/supplements config->>'feeTolerance' with a typed first-class column.
  toleranceBps      Int?     @map("tolerance_bps")
  // Policy schema version — bump when breaking changes are made to config structure.
  version           Int      @default(1)
  // Extra protocol-specific knobs (e.g. Stripe currency codes, AP2 TTL overrides).
  config            Json?    @default("{}")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([protocol])
  @@index([isActive])
  @@map("matching_policies")
}

// Append-only event log for every state change in the settlement lifecycle.
// Mirrors the role of trust_events for the settlement domain — immutable, indexed,
// and decoupled from the intent/transaction tables.
model SettlementEvent {
  id                   String    @id @default(cuid())
  // FK to settlement_identities; nullable because events can be emitted before
  // a SettlementIdentity record exists (e.g. premature hash submission).
  settlementIdentityId String?   @map("settlement_identity_id") @db.Uuid
  // Denormalised intent reference for fast per-intent event queries.
  intentId             String?   @map("intent_id") @db.Uuid
  // Discriminates the lifecycle step:
  // hash_submitted | on_chain_confirmed | webhook_received
  // | resolution_failed | expired | policy_mismatch
  eventType            String    @map("event_type")
  protocol             String
  externalRef          String?   @map("external_ref")
  // Raw proof payload as received from the chain or provider.
  payload              Json      @default("{}")
  // Where the proof originated: 'onchain' | 'webhook' | 'api' | 'listener' | …
  proofSource          String?   @map("proof_source")
  // Raw cryptographic signature from the chain or provider (base58 / hex).
  // Preserved for future x402/AP2 signed-receipt verification.
  rawProofSignature    String?   @map("raw_proof_signature")
  // Structured reasoning / mismatch detail (complements payload).
  details              Json?
  // When the event was actually observed (distinct from createdAt which is DB insertion time).
  observedAt           DateTime? @map("observed_at") @db.Timestamptz(6)
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  settlementIdentity SettlementIdentity? @relation(fields: [settlementIdentityId], references: [id])

  @@index([settlementIdentityId])
  @@index([intentId])
  @@index([eventType])
  @@index([createdAt(sort: Desc)])
  // Compound index: identity events ordered by observation time.
  @@index([settlementIdentityId, observedAt(sort: Desc)])
  // Compound index: protocol-scoped proof lookups.
  @@index([protocol, externalRef])
  @@map("settlement_events")
}

// One record per intent. Written exactly once when the resolution engine
// finalises the outcome (confirmed / failed / disputed / expired).
// Provides a single, queryable source of truth for "was this intent paid?"
// without requiring a join across payment_intents + transactions.
model IntentResolution {
  id                   String    @id @default(uuid()) @db.Uuid
  intentId             String    @unique @map("intent_id") @db.Uuid
  // FK to the SettlementIdentity that provided the winning proof.
  // Null for resolutions that close without on-chain evidence (e.g. expired).
  // @unique ensures at most one IntentResolution per SettlementIdentity.
  settlementIdentityId String?   @unique @map("settlement_identity_id") @db.Uuid
  protocol             String
  // Which subsystem wrote this record:
  // solana_listener | stripe_webhook | ap2_confirm | manual
  resolvedBy           String    @map("resolved_by")
  // confirmed | failed | disputed | expired
  resolutionStatus     String    @map("resolution_status")
  // Phase 6: fine-grained decision from the resolution engine
  // matched | matched_with_external_fee | partial_match | underpaid | overpaid | unmatched | rejected
  decisionCode         String?   @map("decision_code")
  // Phase 6: machine-readable reason for the decision
  reasonCode           String?   @map("reason_code")
  // Phase 6: engine confidence score (0.000 – 1.000) — kept for backward compat
  confidenceScore      Decimal?  @map("confidence_score") @db.Decimal(4, 3)
  // Phase 035: 0-100 integer confidence score (preferred representation going forward).
  // DB CHECK constraint enforces 0 ≤ value ≤ 100 (see migration 035).
  confidencePct        Int?      @map("confidence_pct")
  // Phase 035: structured reasoning / mismatch detail from the resolution engine
  // (e.g. amount delta, memo comparison, recipient check output).
  details              Json?
  externalRef          String?   @map("external_ref")
  confirmationDepth    Int?      @map("confirmation_depth")
  // Payer address (Solana wallet) or Stripe customer ID — protocol-specific.
  payerRef             String?   @map("payer_ref")
  resolvedAt           DateTime  @map("resolved_at") @db.Timestamptz(6)
  metadata             Json?     @default("{}")
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  intent             PaymentIntent       @relation(fields: [intentId], references: [id])
  // onDelete: Restrict — a SettlementIdentity named as the winning proof cannot
  // be deleted while this resolution record exists, preserving the audit trail.
  settlementIdentity SettlementIdentity? @relation(fields: [settlementIdentityId], references: [id], onDelete: Restrict)

  @@index([intentId])
  @@index([externalRef])
  @@index([resolutionStatus])
  @@index([decisionCode])
  // Composite index: intent-scoped decision lookup (Phase 035).
  @@index([intentId, decisionCode])
  @@map("intent_resolutions")
}

model TrustEdge {
  id               String   @id @default(cuid())
  fromAgentId      String   @map("from_agent")
  toAgentId        String   @map("to_agent")
  trustWeight      Float    @default(0) @map("trust_weight")
  interactionCount Int      @default(0) @map("interaction_count")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([fromAgentId])
  @@index([toAgentId])
  @@unique([fromAgentId, toAgentId])
  @@map("trust_edges")
}
