  hiring_agent             String
  working_agent            String
  amount_usdc              Decimal   @db.Decimal(20, 6)
  status                   String    @default("funded")
  work_description         String?
  deadline                 DateTime? @db.Timestamptz(6)
  completed_at             DateTime? @db.Timestamptz(6)
  reputation_delta_hiring  Int       @default(0)
  reputation_delta_working Int       @default(0)
  dispute_reason           String?
  guilty_party             String?
  escrow_account_pubkey    String?
  transaction_signature    String?
  created_at               DateTime? @default(now()) @db.Timestamptz(6)
  updated_at               DateTime? @default(now()) @db.Timestamptz(6)
}

// PRODUCTION FIX — ADDED BY COPILOT: Behavioral oracle alerts table
model behavior_alerts {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agent_id           String
  alert_type         String
  severity           String    @default("low")
  description        String?
  auto_paused        Boolean   @default(false)
  reputation_penalty Int       @default(0)
  metadata           Json?     @default("{}")
  created_at         DateTime? @default(now()) @db.Timestamptz(6)
}

// PRODUCTION FIX — ADDED BY COPILOT: KYA (Know Your Agent) identity table
model agent_identities {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agent_id        String    @unique
  owner_email     String
  owner_id        String?
  verified        Boolean   @default(false)
  kyc_status      String    @default("pending")
  risk_score      Decimal   @default(0) @db.Decimal(5, 2)
  stripe_account  String?
  platform_token  String?
  world_id_hash   String?
  metadata        Json?     @default("{}")
  created_at      DateTime? @default(now()) @db.Timestamptz(6)
  updated_at      DateTime? @default(now()) @db.Timestamptz(6)
}

// PRODUCTION FIX — INSURANCE POOL TABLE
// Backstop for the Behavioral Oracle — holds USDC reserves for automated
// insurance payouts when critical alerts trigger reputation slashing.
// Migration: npx prisma db push  (or add migration via npx prisma migrate dev)
model insurance_pool {
  id                   Int      @id @default(autoincrement())
  current_balance_usdc Decimal  @db.Decimal(20, 6)
  max_coverage_per_tx  Decimal  @default(100.00) @db.Decimal(20, 6)
  total_claims         Int      @default(0)
  updated_at           DateTime @updatedAt

  @@map("insurance_pool")
}

// PRODUCTION FIX — ADDED BY COPILOT: Dispute resolution cases table
model dispute_cases {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  escrow_id        String
  hiring_agent     String
  working_agent    String
  amount_usdc      Decimal   @db.Decimal(20, 6)
  evidence         Json?     @default("{}")
  completion_score Decimal?  @db.Decimal(5, 3)
  peer_reviews     Json?     @default("[]")
  outcome          String?
  worker_payout    Decimal   @default(0) @db.Decimal(20, 6)
  hirer_refund     Decimal   @default(0) @db.Decimal(20, 6)
  resolved         Boolean   @default(false)
  resolved_at      DateTime? @db.Timestamptz(6)
  created_at       DateTime? @default(now()) @db.Timestamptz(6)
}

// Hosted/custodial wallet for walletless agents (e.g. Moltbook bots).
// The private key is stored AES-256-GCM encrypted via walletEncryption.ts.
model agent_wallets {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agent_id              String    @unique
  public_key            String
  encrypted_private_key String
  balance_usdc          Decimal   @default(0) @db.Decimal(20, 6)
  label                 String?
  is_active             Boolean   @default(true)
  created_at            DateTime? @default(now()) @db.Timestamptz(6)
  updated_at            DateTime? @default(now()) @db.Timestamptz(6)

  @@map("agent_wallets")
}
