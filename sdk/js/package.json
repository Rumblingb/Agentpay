{
  "name": "@agentpayxyz/sdk",
  "version": "0.3.0",
  "description": "JavaScript/TypeScript SDK for AgentPay - Universal payment gateway for AI agents",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "agentpay",
    "payments",
    "ai-agents",
    "autonomous-agents",
    "agent-economy",
    "agentpassport",
    "solana",
    "usdc",
    "sdk",
    "x402",
    "mcp"
  ],
  "author": "AgentPay",
  "license": "BSL-1.1; AGPL-3.0 after 2029-01-01",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Rumblingb/Agentpay.git",
    "directory": "sdk/js"
  },
  "homepage": "https://github.com/Rumblingb/Agentpay/tree/main/sdk/js#readme",
  "bugs": {
    "url": "https://github.com/Rumblingb/Agentpay/issues"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "jest": {
    "preset": "ts-jest/presets/default-esm",
    "testEnvironment": "node",
    "extensionsToTreatAsEsm": [".ts"],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "useESM": true,
          "diagnostics": false
        }
      ]
    }
  }
}
