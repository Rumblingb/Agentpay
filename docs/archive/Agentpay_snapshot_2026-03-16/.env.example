# ============================================================================
# AgentPay Backend — Environment Variables
# Copy this file to .env and fill in the values.
# ============================================================================
# All variables marked [REQUIRED] must be set before the server will start in
# production.  Variables marked [optional] can be omitted; defaults are shown.
# Generate strong secrets with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ============================================================================

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3001
# Valid values: development | test | production
NODE_ENV=development
LOG_LEVEL=info

# ── Database ─────────────────────────────────────────────────────────────────
# [REQUIRED] Pooled connection string used for all runtime queries.
DATABASE_URL=postgresql://YOUR_USER:YOUR_PASSWORD@YOUR_HOST:5432/YOUR_DATABASE

# [optional] Direct (non-pooled) connection used by Prisma Migrate.
# Required when running migrations against Supabase (pgBouncer pooler strips
# advisory lock support that Prisma needs).
# DIRECT_URL=postgresql://YOUR_USER:YOUR_PASSWORD@YOUR_HOST:5432/YOUR_DATABASE

# ── Required secrets ─────────────────────────────────────────────────────────
# The server refuses to start in production if these are missing, too short
# (<32 chars), or set to the placeholder values below.

# HMAC-SHA256 secret for signing outgoing webhook payloads.
# Merchants verify: X-AgentPay-Signature: sha256=<hmac>
WEBHOOK_SECRET=change-me-in-production

# HMAC secret for AP2 payment receipt signatures and AES-256-GCM wallet encryption.
AGENTPAY_SIGNING_SECRET=your-signing-secret-here

# HMAC secret for verification certificate signatures.
VERIFICATION_SECRET=your-verification-secret-here

# Bearer token required by admin API endpoints (x-admin-key header).
# [optional in dev — defaults to 'admin-dev-key' with a warning]
# ADMIN_SECRET_KEY=your-admin-key-here

# ── URLs & CORS ───────────────────────────────────────────────────────────────
# Comma-separated allowed CORS origins.
# Vercel preview URLs (https://*agentpay*.vercel.app) are auto-allowed.
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3001

# Public base URL of this API server — used by protocol handlers (ACP, x402)
# and when building Stripe Connect callback URLs.
# In production set this to your Render URL, e.g. https://agentpay.onrender.com
API_BASE_URL=http://localhost:3001

# Base URL of the merchant dashboard — used for post-payment redirects.
FRONTEND_URL=http://localhost:3000

# ── Solana ────────────────────────────────────────────────────────────────────
SOLANA_RPC_URL=https://api.devnet.solana.com
# Minimum on-chain confirmations before a payment is considered final.
CONFIRMATION_DEPTH=2
# [optional] Helius API key for Solana analytics / AgentRank enrichment.
# Get a free key at https://helius.dev
# HELIUS_API_KEY=your_helius_api_key_here

# ── Stripe (optional) ─────────────────────────────────────────────────────────
# Leave blank to disable Stripe integration.
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# STRIPE_SUCCESS_URL=https://your-dashboard.example.com/payment/success
# STRIPE_CANCEL_URL=https://your-dashboard.example.com/payment/cancel

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_MAX_REQUESTS=100

# ── Feature flags ─────────────────────────────────────────────────────────────
# AGENTPAY_TEST_MODE=true accepts the bypass key sk_test_sim.
# Must be false (or unset) in production.
AGENTPAY_TEST_MODE=false

# Emergency circuit-breaker: set to true to immediately halt all new payments.
# AGENTPAY_GLOBAL_PAUSE=false

# Disable the automatic liquidity rebalancing cron job.
# LIQUIDITY_BOT_ENABLED=true

# ── Spending-policy defaults ──────────────────────────────────────────────────
# DEFAULT_AUTO_APPROVE_UNDER_CENTS=500
# DEFAULT_DAILY_LIMIT_CENTS=1000000
# DEFAULT_PER_TX_LIMIT_CENTS=100000
# DEFAULT_MIN_AGENT_RANK=0
# WALLET_MAX_SEND_USDC=100000

# ── Platform ──────────────────────────────────────────────────────────────────
# DEFAULT_PLATFORM_ID=default

# ── KYC / blocklists (optional) ───────────────────────────────────────────────
# Comma-separated Solana wallet addresses to reject.
# BLACKLISTED_WALLETS=addr1,addr2
# Comma-separated IP prefixes (CIDR) to block.
# BLACKLISTED_IP_PREFIXES=1.2.3.0/24
# Comma-separated two-letter region codes treated as high-risk.
# HIGH_RISK_REGIONS=KP,IR

# ── Optional integrations ─────────────────────────────────────────────────────
# Sentry error tracking (leave blank to disable).
# SENTRY_DSN=https://YOUR_SENTRY_DSN@o123456.ingest.sentry.io/123456

# OpenAI API key (used by AI-powered features).
# OPENAI_API_KEY=sk-...

# Base58-encoded private key for the on-chain IdentityVerifierAgent.
# Leave unset to use an ephemeral (non-persistent) key in development.
# IDENTITY_VERIFIER_PRIVATE_KEY=your_base58_private_key_here
