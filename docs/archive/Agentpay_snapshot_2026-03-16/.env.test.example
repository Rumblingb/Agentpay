# Minimal environment example for running tests locally
# Copy this to .env.test (or set env vars) before running `npm test`.
# Notes:
# - Use `NODE_ENV=test` to enable test-mode routes and avoid production fast-fail.
# - These values are examples only; do NOT use them in production.

NODE_ENV=test
PORT=3001
LOG_LEVEL=info

# Database - point to a local test DB or a Docker container
DATABASE_URL=postgres://postgres:postgres@localhost:5432/agentpay_test
DIRECT_URL=

# Secrets - test-safe placeholders
WEBHOOK_SECRET=webhook-test-secret
AGENTPAY_SIGNING_SECRET=signing-test-secret
VERIFICATION_SECRET=verification-test-secret
ADMIN_SECRET_KEY=admin-dev-key

# Optional integrations (leave blank in tests)
SENTRY_DSN=
OPENAI_API_KEY=

# Feature flags
AGENTPAY_TEST_MODE=true
AGENTPAY_GLOBAL_PAUSE=false
LIQUIDITY_BOT_ENABLED=false

# URLs
API_BASE_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# Rate limits
RATE_LIMIT_MAX_REQUESTS=100
