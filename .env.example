# Server
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://postgres:Agentpay2026@db.yndlhhkhylwihsggdyru.supabase.co:5432/postgres

# Solana
SOLANA_RPC_URL=https://api.devnet.solana.com
