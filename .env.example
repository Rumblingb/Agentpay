# Server
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://YOUR_USER:YOUR_PASSWORD@YOUR_HOST:5432/YOUR_DATABASE

# Solana
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_NETWORK=devnet
CONFIRMATION_DEPTH=2

# Payment
PAYMENT_EXPIRY_MINUTES=30

# Security
# In production, include your Vercel dashboard domain, e.g.:
# CORS_ORIGIN=https://apay-delta.vercel.app,https://agentpay-eq6y.onrender.com
# Vercel preview deployments (https://*-<team>.vercel.app) are allowed automatically
# by the CORS middleware — no need to list them here individually.
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3001
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# API Key helper
# AGENTPAY_TEST_KEY is a convenience variable for the Vercel dashboard so it
# knows which API key belongs to this deployment.  It is NOT read by the Express
# backend — auth always uses PBKDF2 DB verification.  If you change your key
# (e.g. via POST /api/merchants/rotate-key), update this value in Vercel too.
# Generate the matching DB record with:
#   node scripts/generate-hash.cjs <key> <email>
# AGENTPAY_TEST_KEY=ak_live_<your-key-here>

# Webhooks — shared secret used to sign outgoing webhook payloads (HMAC-SHA256)
# Merchants verify: X-AgentPay-Signature: sha256=<hmac>
WEBHOOK_SECRET=change-me-in-production
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret-here

# Signing — used for AP2 receipt HMAC signatures
AGENTPAY_SIGNING_SECRET=your-signing-secret-here

# Verification — used for certificate signing
VERIFICATION_SECRET=your-verification-secret-here

# Sentry — optional error tracking (leave blank to disable)
# SENTRY_DSN=https://YOUR_SENTRY_DSN@o123456.ingest.sentry.io/123456

# Helius — Solana RPC + analytics for multi-source AgentRank enrichment
# Get a free key at https://helius.dev
# HELIUS_API_KEY=your_helius_api_key_here
