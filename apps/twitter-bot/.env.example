# ── Twitter API v2 credentials (developer.twitter.com) ───────────────────
TWITTER_API_KEY=your_api_key_here
TWITTER_API_SECRET=your_api_secret_here
TWITTER_ACCESS_TOKEN=your_access_token_here
TWITTER_ACCESS_SECRET=your_access_secret_here
TWITTER_BEARER_TOKEN=your_bearer_token_here

# ── Bot identity ──────────────────────────────────────────────────────────
TWITTER_BOT_HANDLE=AgentPay

# ── AgentPay backend ──────────────────────────────────────────────────────
AGENTPAY_BASE_URL=http://localhost:3001
AGENTPAY_API_KEY=your_agentpay_api_key_here
AGENTPAY_MERCHANT_ID=your_default_merchant_uuid
AGENTPAY_BOT_AGENT_ID=twitter-bot-agent

# ── Spending limits ───────────────────────────────────────────────────────
# Hard-cap daily spend per user in USD (default: 20)
DAILY_LIMIT_USD=20

# ── Webhook server ────────────────────────────────────────────────────────
PORT=4000
# Shared secret for validating incoming Solana confirmation webhooks
SOLANA_WEBHOOK_SECRET=change-me-to-a-random-secret
