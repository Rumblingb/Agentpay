EXPO_PUBLIC_API_URL=https://api.agentpay.so
EXPO_PUBLIC_BRO_KEY=replace-with-bro-client-key
# Set to "false" to force Skia runtime even on eligible iOS builds (debug/QA use)
# Omit or set to "true" to enable 3D on iOS builds >= build 10 with GLView support
EXPO_PUBLIC_ACE_3D_ENABLED=true
# Do not place OpenAI, Anthropic, or payment secrets in Expo public env vars.
