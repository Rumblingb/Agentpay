# ignore-scripts was removed — it blocks native module post-install (reanimated, stripe, etc.)
# which breaks Gradle codegen on EAS builds

# Disable npm workspaces — this app is built standalone on EAS; the monorepo
# root package.json (workspaces: ['apps/*', ...]) otherwise causes npm to hoist
# packages incorrectly and installs wrong versions of expo-modules-core etc.
workspaces=false
