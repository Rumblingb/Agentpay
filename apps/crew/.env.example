ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
AGENTPAY_API_URL=https://api.agentpay.so
BRO_CLIENT_KEY=your-bro-client-key

# OpenClaw — automated train ticket fulfillment
# Get your API key from the OpenClaw dashboard
OPENCLAW_API_KEY=your-openclaw-key
OPENCLAW_API_URL=https://api.openclaw.io

# Gemini (optional — enable billing at aistudio.google.com to remove RPD limits)
# Leave blank to use CF Workers AI Llama for extraction (free, no limits)
GEMINI_API_KEY=

# Crew API key — set this to protect /crew/* endpoints when running the server
CREW_API_KEY=your-crew-api-key
