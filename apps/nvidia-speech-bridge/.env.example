PORT=8788
NVIDIA_SPEECH_BRIDGE_TOKEN=<32+ char random string>
FFMPEG_PATH=

# Point these at your deployed NVIDIA speech NIM HTTP surfaces.
# ASR tutorial: POST /v1/audio/transcriptions
# TTS tutorial: POST /v1/audio/synthesize
NVIDIA_ASR_BASE_URL=http://127.0.0.1:9000
NVIDIA_TTS_BASE_URL=http://127.0.0.1:9001

# Optional bearer auth if your NIM surface is protected.
NVIDIA_SPEECH_API_KEY=

# AgentPay defaults for Ace.
NVIDIA_ASR_LANGUAGE_CODE=en-US
NVIDIA_ASR_SAMPLE_RATE_HZ=16000
NVIDIA_TTS_LANGUAGE_CODE=en-US
NVIDIA_TTS_VOICE_NAME=Magpie-Multilingual.EN-US.Aria
