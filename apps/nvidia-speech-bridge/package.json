{
  "name": "@agentpay/nvidia-speech-bridge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Internal bridge for NVIDIA Speech NIM STT/TTS from AgentPay edge routes",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node --enable-source-maps dist/server.js",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.8.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
