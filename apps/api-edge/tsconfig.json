{
  "compilerOptions": {
    // Workers run on V8 but wrangler bundles with esbuild targeting ES2022.
    "target": "ES2022",

    // Wrangler (esbuild) resolves imports at bundle time — use "Bundler"
    // so TypeScript does NOT add .js extensions or require index.ts discovery.
    "module": "ESNext",
    "moduleResolution": "Bundler",

    // Workers provide Web APIs (fetch, crypto, URL, Headers …) via
    // @cloudflare/workers-types.  Do NOT include "DOM" — it conflicts with
    // the Workers global scope types for Response, Request, etc.
    "lib": ["ES2022"],

    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,

    // No output — wrangler/esbuild handles the actual compilation.
    "noEmit": true,

    // Type-only imports for Workers globals (no DOM types).
    "types": ["@cloudflare/workers-types"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}
