# .env.test — environment for running tests locally via docker-compose.
# Start the database first: docker-compose up -d
# Then run: npm run test:full

# ── Server ─────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=test

# ── Database ───────────────────────────────────────────────────────────────
# Matches the docker-compose.yml test-db service (port 5433 avoids conflicts
# with any locally-running Postgres on the default 5432).
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/agentpay_test

# ── Test mode ──────────────────────────────────────────────────────────────
# Enables /api/test/* routes (force-verify, etc.).  Must be "true".
AGENTPAY_TEST_MODE=true

# ── Solana (unused in test mode, but required by the module) ───────────────
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_NETWORK=devnet
CONFIRMATION_DEPTH=2

# ── Webhooks ───────────────────────────────────────────────────────────────
WEBHOOK_SECRET=test-secret-change-in-production

# ── Stripe (dummy key so the Stripe SDK loads without throwing) ────────────
STRIPE_SECRET_KEY=sk_test_mock_key_for_local_testing

# ── App URL ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3000
