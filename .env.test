# .env.test — example environment for running tests locally
# Copy to .env (or export these vars) before running `npm test`.

# ── Server ─────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=test

# ── Database ───────────────────────────────────────────────────────────────
# Point at a local Postgres instance (or use the Docker compose below).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agentpay_test

# ── Test mode ──────────────────────────────────────────────────────────────
# Enables /api/test/* routes (force-verify, etc.).  Must be "true".
AGENTPAY_TEST_MODE=true

# ── Solana (unused in test mode, but required by the module) ───────────────
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_NETWORK=devnet
CONFIRMATION_DEPTH=2

# ── Webhooks ───────────────────────────────────────────────────────────────
WEBHOOK_SECRET=test-secret-change-in-production
