# AgentPay Dashboard — Environment Variables
# Copy this file to .env.local and fill in the values.
#
# Architecture:
#   Backend (Cloudflare Workers) runs at https://api.agentpay.so
#   Dashboard (Next.js / Vercel) runs on http://localhost:3000  (default Next.js port)
#
# The dashboard's API routes act as a secure BFF (Backend-for-Frontend): they
# read the session cookie, extract the merchant's API key, and forward requests
# to the Workers backend. AGENTPAY_API_BASE_URL must point at the Workers API.
#
# In production (Vercel + Cloudflare Workers) set AGENTPAY_API_BASE_URL to:
#   https://api.agentpay.so
# Next.js rewrites in next.config.ts also proxy unmatched /api/* paths to this URL.

# URL of the AgentPay backend API (server-side; used by BFF routes & Next.js rewrites)
AGENTPAY_API_BASE_URL=http://localhost:3001

# Secret for HMAC-signing the HTTP-only session cookie.
# Must be at least 32 random characters. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DASHBOARD_SESSION_SECRET=change-me-to-a-random-32-char-secret

# Internal API key used by server-side dashboard routes (e.g. receipt page) to
# authenticate requests to the backend without a session cookie.
# Leave unset in development; set to a valid merchant API key in production.
# AGENTPAY_INTERNAL_API_KEY=ak_live_<your-key-here>

# The merchant API key for this deployment.
# This value is stored in the session cookie after successful login — it is
# NOT sent to the browser and NOT read server-side to auto-authenticate.
# Its only purpose here is as a reminder of which key was used to register.
#
# To generate a valid database record for an existing key, run:
#   node scripts/generate-hash.cjs <key> <email>
# Then paste the printed SQL into Supabase / psql.
#
# IMPORTANT: the value must be the raw key (e.g. ak_live_…) WITHOUT the
# "Bearer " prefix — the BFF adds "Bearer " automatically when calling the backend.
# AGENTPAY_TEST_KEY=ak_live_<your-key-here>
