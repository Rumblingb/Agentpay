# AgentPay Dashboard — Environment Variables
# Copy this file to .env.local and fill in the values.
#
# Architecture:
#   Backend (Express API) runs on http://localhost:3001
#   Dashboard (Next.js)  runs on http://localhost:3000  (default Next.js port)
#
# The dashboard's API routes act as a secure BFF (Backend-for-Frontend): they
# read the session cookie, extract the merchant's API key, and forward requests
# to the backend.  All AGENTPAY_API_BASE_URL / NEXT_PUBLIC_API_URL values
# should therefore point at the backend, NOT at the dashboard itself.

# URL of the AgentPay backend API (public, used by client-side calls)
NEXT_PUBLIC_API_URL=http://localhost:3001

# URL of the AgentPay backend API (server-side; can be the same or an internal address)
AGENTPAY_API_BASE_URL=http://localhost:3001

# Secret for HMAC-signing the HTTP-only session cookie.
# Must be at least 32 random characters. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DASHBOARD_SESSION_SECRET=change-me-to-a-random-32-char-secret
