#!/bin/bash
set -euo pipefail
root="$(cd -- "$(dirname -- "$0")/../../.." && pwd)"
export PATH="/opt/homebrew/opt/node/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:${PATH:-}"
node_bin="$(command -v node || true)"
if [[ -z "$node_bin" && -x /opt/homebrew/bin/node ]]; then
  node_bin="/opt/homebrew/bin/node"
fi
if [[ -z "$node_bin" ]]; then
  echo "agency-os-evolve: node not found" >&2
  exit 1
fi
exec "$node_bin" "$root/ops/mac-mini/scripts/agency-os-evolve.mjs"
