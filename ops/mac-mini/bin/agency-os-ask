#!/bin/bash
set -euo pipefail
source "$(dirname -- "$0")/_stack-common.sh"
lane="all"
if [[ "${1:-}" == "--lane" ]]; then
  lane="${2:-}"
  shift 2
fi
message="$(stack_read_message "$@")"
if [[ -z "${message// }" ]]; then
  echo "Usage: agency-os-ask [--lane all|jack|bigb|chief-agent|digital-you] \"message\"" >&2
  exit 2
fi
agency_inbox="$(stack_agency_workspace)/INBOX.md"
stack_append_entry "$agency_inbox" "Founder request (${lane})" "$message"
if [[ "$lane" == "all" ]]; then
  for item in jack bigb chief-agent digital-you; do
    stack_append_entry "$(stack_lane_workspace "$item")/INBOX.md" "Agency OS request" "$message"
  done
else
  stack_append_entry "$(stack_lane_workspace "$lane")/INBOX.md" "Agency OS request" "$message"
fi
printf 'Wrote Agency OS inbox: %s\n' "$agency_inbox"
