#!/bin/bash
set -euo pipefail
if ! command -v tmux >/dev/null 2>&1; then
  echo 'tmux is required for stack-dashboard. Install it first or use stack-watch.' >&2
  exit 2
fi
session_name="agency-bill-stack"
base_dir="$(cd -- "$(dirname -- "$0")" && pwd)"
if tmux has-session -t "$session_name" 2>/dev/null; then
  exec tmux attach -t "$session_name"
fi

tmux new-session -d -s "$session_name" "$base_dir/stack-watch 10"
tmux split-window -h -t "$session_name":0 "$base_dir/stack-activity-watch 10"
tmux split-window -v -t "$session_name":0.0 "$base_dir/stack-openclaw-watch 20"
tmux split-window -v -t "$session_name":0.1 'tail -f /Users/baskar_viji/hedge/.rumbling-hedge/logs/launchd-prediction-cycle.log'
tmux select-layout -t "$session_name":0 tiled
exec tmux attach -t "$session_name"
