# =============================================================================
# AgentPay — Production Environment Variables
# =============================================================================
# IMPORTANT: All values marked with [REQUIRED] will cause the server to
# refuse to start if they are missing or set to insecure defaults.
# Generate strong secrets with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# =============================================================================

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
LOG_LEVEL=warn

# ── Database (PostgreSQL / Supabase) [REQUIRED] ───────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/agentpay?sslmode=require
# Direct (non-pooled) URL for Prisma Migrate — required for Supabase pgBouncer.
DIRECT_URL=postgresql://user:password@host:5432/agentpay?sslmode=require

# ── Required secrets [REQUIRED] ───────────────────────────────────────────────
# HMAC-SHA256 secret for signing outgoing webhook payloads.
WEBHOOK_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET

# HMAC secret for AP2 payment receipt signatures and wallet encryption.
AGENTPAY_SIGNING_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET

# HMAC secret for verification certificate signatures.
VERIFICATION_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET

# Bearer token for admin API endpoints (x-admin-key header).
ADMIN_SECRET_KEY=REPLACE_WITH_STRONG_RANDOM_SECRET

# ── URLs & CORS [REQUIRED] ────────────────────────────────────────────────────
CORS_ORIGIN=https://yourdomain.com,https://dashboard.yourdomain.com

# Public base URL of this API server (used by protocol handlers and Stripe callbacks).
API_BASE_URL=https://api.agentpay.so

# Base URL of the merchant dashboard (used for post-payment redirects).
FRONTEND_URL=https://dashboard.yourdomain.com

# ── Solana ─────────────────────────────────────────────────────────────────────
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
CONFIRMATION_DEPTH=10

# ── Stripe ─────────────────────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_live_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# STRIPE_SUCCESS_URL=https://dashboard.yourdomain.com/payment/success
# STRIPE_CANCEL_URL=https://dashboard.yourdomain.com/payment/cancel

# ── Dashboard (Vercel) [REQUIRED] ─────────────────────────────────────────────
# HMAC secret for signing HTTP-only session cookies.
# Must be at least 32 random characters.
DASHBOARD_SESSION_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET_MIN_32_CHARS

# ── Rate limiting ──────────────────────────────────────────────────────────────
RATE_LIMIT_MAX_REQUESTS=100

# ── Feature flags ──────────────────────────────────────────────────────────────
# Must be false in production — true exposes /api/test routes and bypass keys.
AGENTPAY_TEST_MODE=false

# ── Spending-policy defaults ───────────────────────────────────────────────────
# DEFAULT_AUTO_APPROVE_UNDER_CENTS=500
# DEFAULT_DAILY_LIMIT_CENTS=1000000
# DEFAULT_PER_TX_LIMIT_CENTS=100000
# DEFAULT_MIN_AGENT_RANK=0
# WALLET_MAX_SEND_USDC=100000

# ── Optional integrations ──────────────────────────────────────────────────────
# SENTRY_DSN=https://YOUR_SENTRY_DSN@o123456.ingest.sentry.io/123456
# HELIUS_API_KEY=your_helius_api_key_here
# OPENAI_API_KEY=sk-...

# ── KYC / blocklists ───────────────────────────────────────────────────────────
# BLACKLISTED_WALLETS=addr1,addr2
# BLACKLISTED_IP_PREFIXES=1.2.3.0/24
# HIGH_RISK_REGIONS=KP,IR
