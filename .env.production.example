# =============================================================================
# AgentPay — Production Environment Variables
# =============================================================================
# IMPORTANT: All values marked with *** REQUIRED *** will cause the server to
# refuse to start if they are missing or set to insecure defaults.
# Generate strong secrets with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# =============================================================================

# --- Server ---
PORT=3001
NODE_ENV=production

# --- Database (PostgreSQL / Supabase) ***REQUIRED*** ---
DATABASE_URL=postgresql://user:password@host:5432/agentpay?sslmode=require
DIRECT_URL=postgresql://user:password@host:5432/agentpay?sslmode=require

# --- Solana ---
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_CONFIRMATION_DEPTH=2
SOLANA_NETWORK=mainnet-beta

# --- Stripe ---
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- Security ***REQUIRED*** ---
CORS_ORIGIN=https://yourdomain.com,https://dashboard.yourdomain.com
RATE_LIMIT_MAX_REQUESTS=100

# Webhooks — shared secret used to sign outgoing webhook payloads (HMAC-SHA256) ***REQUIRED***
WEBHOOK_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET

# AP2 receipt HMAC signing secret ***REQUIRED***
AGENTPAY_SIGNING_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET

# Certificate HMAC signing secret ***REQUIRED***
VERIFICATION_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET

# --- Dashboard (Vercel) ***REQUIRED*** ---
# HMAC secret for signing HTTP-only session cookies.
# If missing in production, session creation throws and the dashboard is unusable.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DASHBOARD_SESSION_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET_MIN_32_CHARS

# --- Logging ---
LOG_LEVEL=info

# --- AgentRank ---
AGENTRANK_MIN_STAKE_USDC=100
AGENTRANK_SYBIL_CHECK_ENABLED=true

# --- Escrow ---
ESCROW_AUTO_RELEASE_HOURS=24
ESCROW_DEFAULT_DEADLINE_HOURS=72

# --- KYA (Know Your Agent) ---
KYA_AUTO_VERIFY=true

# --- Behavioral Oracle ---
BEHAVIORAL_ORACLE_ENABLED=true
PREDATORY_DISPUTE_THRESHOLD=0.5
RAPID_ESCALATION_WINDOW_HOURS=24

# --- Test Mode (disable in production) ---
# Set AGENTPAY_TEST_MODE=false in production.
# When true, the API accepts 'sk_test_sim' and 'sk_test_sim_12345' as bypass keys.
AGENTPAY_TEST_MODE=false
