{
  "name": "agentpay",
  "version": "0.1.0",
  "type": "module",
  "description": "Universal payment gateway for AI agents",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "start:prod": "NODE_ENV=production node dist/server.js",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:security": "jest --testPathPattern=security",
    "db:create": "node scripts/create-db.js",
    "db:migrate": "node scripts/migrate.js",
    "db:setup": "npm run db:create && npm run db:migrate",
    "clean": "rm -rf dist",
    "clean:build": "npm run clean && npm run build",
    "lint": "echo 'Linting not configured yet'",
    "validate": "npm run build && npm test",
    "prestart": "npm run build",
    "prepare": "npm run build"
  },
  "keywords": [
    "payments",
    "ai-agents",
    "x402",
    "fintech"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "@solana/spl-token": "^0.1.8",
    "@solana/web3.js": "^1.91.0",
    "axios": "^1.6.5",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "crypto": "^1.0.1",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pg": "^8.11.3",
    "pino": "^8.17.2",
    "pino-pretty": "^10.3.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.10.6",
    "@types/pg": "^8.10.9",
    "@types/supertest": "^2.0.12",
    "@types/uuid": "^9.0.7",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.21.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
