{
  "name": "agentpay",
  "version": "0.1.0",
  "type": "module",
  "description": "Trust and payment infrastructure for AI agent-to-agent commerce — AgentRank scoring, A2A escrow, multi-protocol payments, and agent identity",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "bootstrap": "npm install --workspaces",
    "test": "jest --runInBand",
    "test:smoke": "jest --runInBand tests/api-status.test.ts tests/routes/verify.test.ts tests/routes/receipt.test.ts",
    "test:workers-critical": "jest --runInBand tests/routes/wallets.test.ts tests/moltbook/spending-policy.test.ts tests/routes/verify.test.ts tests/routes/receipt.test.ts tests/api-status.test.ts",
    "typecheck": "pnpm -r -w --parallel run typecheck || (tsc -b --verbose)",
    "clean": "rm -rf dist",
    "prisma:generate": "prisma generate --schema=infra/prisma/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema=infra/prisma/schema.prisma",
    "postinstall": "node apps/meridian/scripts/patch-expo-modules.js"
  },
  "keywords": [
    "agentpay",
    "payments",
    "ai-agents",
    "x402",
    "escrow",
    "agentrank",
    "trust",
    "fintech",
    "a2a"
  ],
  "author": "AgentPay",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Rumblingb/Agentpay.git"
  },
  "homepage": "https://github.com/Rumblingb/Agentpay#readme",
  "bugs": {
    "url": "https://github.com/Rumblingb/Agentpay/issues"
  },
  "license": "BSL-1.1; AGPL-3.0 after 2029-01-01",
  "workspaces": [
    "apps/*",
    "packages/*",
    "infra/*"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "undici": "7.24.1",
    "@react-native/js-polyfills": "0.76.9",
    "@react-native/assets-registry": "0.76.9",
    "@react-native/normalize-colors": "0.76.9",
    "@react-native/virtualized-lists": "0.76.9"
  },
  "dependencies": {
    "@sentry/node": "^10.43.0",
    "@solana/web3.js": "^1.98.4",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-rate-limit": "^6.7.0",
    "helmet": "^6.0.1",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "nativewind": "^4.2.3",
    "node-fetch": "^3.3.2",
    "pino": "^10.3.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.17",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^20.3.1",
    "@types/node-fetch": "^2.6.13",
    "@types/pino": "^7.0.4",
    "@types/supertest": "^2.0.12",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.4.6",
    "zod": "^4.3.6"
  }
}
