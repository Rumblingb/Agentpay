{
  "name": "agentpay",
  "version": "0.1.0",
  "type": "module",
  "description": "Trust and payment infrastructure for AI agent-to-agent commerce — AgentRank scoring, A2A escrow, multi-protocol payments, and agent identity",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "local-start": "node ./scripts/local-start.mjs",
    "postinstall": "prisma generate",
    "test": "jest --passWithNoTests --runInBand --forceExit",
    "test:watch": "jest --watch",
    "test:security": "jest --testPathPattern=security",
    "test:full": "docker-compose up -d && node scripts/wait-for-db.js && node scripts/create-db.js && npm test",
    "db:create": "node scripts/create-db.js",
    "db:migrate": "node scripts/migrate.js",
    "agent": "tsx scripts/test-agent.ts",
    "clean": "rm -rf dist",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:studio": "prisma studio",
    "test:debug": "node scripts/debug-errors.js",
    "smoke:test": "tsx scripts/smoke-test-api.ts",
    "calculate-scores": "tsx scripts/calculate-initial-agentrank.ts",
    "generate:secrets": "node scripts/generate-secrets.js",
    "deploy:escrow-devnet": "tsx scripts/deploy-escrow-devnet.ts",
    "seed:foundation-agents": "tsx scripts/seed-foundation-agents.ts",
    "seed:network-agents": "tsx scripts/seed-network-agents.ts",
    "seed:interactions": "tsx scripts/seed-interactions.ts",
    "seed:network": "npm run seed:foundation-agents && npm run seed:network-agents && npm run seed:interactions"
  },
  "keywords": [
    "agentpay",
    "payments",
    "ai-agents",
    "x402",
    "escrow",
    "agentrank",
    "trust",
    "fintech",
    "a2a"
  ],
  "author": "AgentPay",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Rumblingb/Agentpay.git"
  },
  "homepage": "https://github.com/Rumblingb/Agentpay#readme",
  "bugs": {
    "url": "https://github.com/Rumblingb/Agentpay/issues"
  },
  "license": "BSL-1.1; AGPL-3.0 after 2029-01-01",
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.1",
    "@sentry/node": "^10.42.0",
    "@solana/spl-token": "^0.1.8",
    "@solana/web3.js": "^1.91.0",
    "axios": "^1.6.5",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pg": "^8.11.3",
    "pino": "^8.17.2",
    "pino-pretty": "^10.3.1",
    "stripe": "^20.3.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "uuid": "^9.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@prisma/client": "^6.4.1",
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.10.6",
    "@types/node-fetch": "^2.6.13",
    "@types/pg": "^8.10.9",
    "@types/supertest": "^2.0.12",
    "@types/uuid": "^9.0.7",
    "jest": "^29.7.0",
    "playwright": "^1.58.2",
    "prisma": "^6.4.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.1",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.21.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "undici": "7.24.1"
  }
}
